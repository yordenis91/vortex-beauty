// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= Enums =================

enum Role {
  ADMIN
  CLIENT
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE // Añadido: útil para facturas vencidas
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum ClientType {
  CUSTOMER
  SUPPLIER
}

// ================= Models =================

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String?   @unique
  password  String    // Hash de la contraseña (e.g., bcrypt)
  name      String
  role      Role      @default(CLIENT) // ADMIN o CLIENT
  
  // Foto de perfil (Base64)
  imageUrl  String?   @db.Text
  
  // Relación con Client (un user puede estar asociado a un cliente)
  clientId  String?
  client    Client?   @relation("UserAsClient", fields: [clientId], references: [id], onDelete: SetNull)
  
  // Relaciones existentes
  projects  Project[] 
  clients   Client[]  @relation("AdminofClient") // Relación inversa: admin de varios clientes
  invoices  Invoice[]
  
  // Nuevas relaciones para HostBilling
  products      Product[]
  subscriptions Subscription[]
  tickets       Ticket[]       @relation("TicketAssignee")
  ticketCreators Ticket[]      @relation("TicketCreator")
  ticketMessages TicketMessage[]
  knowledgeBase KnowledgeBase[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([clientId])
}

model Client {
  id             String      @id @default(uuid())
  name           String
  email          String      @unique
  code           String?
  displayName    String?
  businessNumber String?
  type           ClientType  @default(CUSTOMER)
  phone          String?
  company        String?
  address        String?     @db.Text
  city           String?
  state          String?
  zipCode        String?
  country        String?
  secondaryEmail String?
  currency       String      @default("USD")
  groupId        String?
  ownerId        String?
  taxId          String?     // CIF/NIF/RUT para la facturación
  
  // Foto de perfil (Base64)
  imageUrl       String?     @db.Text
  
  // Claves foráneas
  userId    String
  user      User      @relation("AdminofClient", fields: [userId], references: [id], onDelete: Cascade)
  
  // Usuarios (clientes) vinculados a este cliente
  clientUsers User[]   @relation("UserAsClient")
  
  // Relaciones existentes
  projects  Project[]
  invoices  Invoice[]

  // Nuevas relaciones para HostBilling
  subscriptions Subscription[]
  tickets       Ticket[]

  // Relación con citas
  appointments  Appointment[]

  // Relación con notificaciones
  notifications Notification[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  
  // Claves foráneas
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  // Relaciones
  invoices    Invoice[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(PENDING)
  
  // Usamos Decimal para evitar errores de coma flotante en dinero
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal       @default(0) @db.Decimal(5, 2) // Porcentaje de impuestos (ej. 21.00)
  totalAmount   Decimal       @db.Decimal(10, 2)
  notes         String?       @db.Text

  // Claves foráneas
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Relaciones
  items         InvoiceItem[]
  orderItems    OrderItem[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clientId])
  @@index([invoiceNumber])
  @@index([userId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  // Clave foránea
  invoiceId   String
  // Si se borra la factura, se borran sus items (Cascade)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ================= Nuevas entidades para HostBilling =================

// Categorías para organizar productos y tickets
model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        CategoryType // PRODUCT, TICKET, KNOWLEDGE_BASE
  color       String?  // Para UI (hex color)
  icon        String?  // Nombre del icono
  order       Int      @default(0) // Para ordenar categorías

  // Relaciones
  products    Product[]
  tickets     Ticket[]
  articles    KnowledgeBase[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, type])
}

// Productos y Servicios
model Product {
  id          String        @id @default(uuid())
  name        String
  description String?       @db.Text
  type        ProductType   // SAAS, WEB_DEVELOPMENT, SUPPORT, MAINTENANCE, CUSTOM_DEVELOPMENT

  // Precios
  price       Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  billingCycle BillingCycle // MONTHLY, YEARLY, ONE_TIME, QUARTERLY

  // Estado y configuración
  status      ProductStatus @default(ACTIVE)
  isPublic    Boolean       @default(true)  // Visible en portal de cliente
  stock       Int?          // Para productos limitados (null = unlimited)

  // Categorización
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])

  // Usuario que creó el producto
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  // Relaciones
  subscriptions Subscription[]
  orderItems   OrderItem[]
  appointments Appointment[]
  galleryItems GalleryItem[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([userId])
  @@index([type])
}

model GalleryItem {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String   @db.Text
  isActive    Boolean  @default(true)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
}

// Órdenes/Suscripciones
model Subscription {
  id            String            @id @default(uuid())
  subscriptionNumber String       @unique
  status        SubscriptionStatus @default(ACTIVE)

  // Fechas importantes
  startDate     DateTime          @default(now())
  endDate       DateTime?
  nextBilling   DateTime?
  cancelledAt   DateTime?

  // Producto suscrito
  productId     String
  product       Product           @relation(fields: [productId], references: [id])

  // Cliente suscriptor
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])

  // Usuario que gestiona
  userId        String
  user          User              @relation(fields: [userId], references: [id])

  // Configuración de facturación
  autoRenew     Boolean           @default(true)
  notes         String?           @db.Text

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([userId])
  @@index([status])
}

// Items de órdenes (para compras únicas)
model OrderItem {
  id        String  @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  // Relación con invoice (opcional, para compras que generan factura)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([invoiceId])
}

// Sistema de Tickets de Soporte
model Ticket {
  id          String       @id @default(uuid())
  ticketNumber String      @unique
  subject     String
  description String       @db.Text
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)

  // Categorización
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id])

  // Cliente que creó el ticket
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id])

  // Usuario asignado (agente de soporte)
  assignedToId String?
  assignedTo   User?       @relation("TicketAssignee", fields: [assignedToId], references: [id])

  // Usuario que creó el ticket
  userId      String
  user        User         @relation("TicketCreator", fields: [userId], references: [id])

  // Relaciones
  messages    TicketMessage[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([clientId])
  @@index([categoryId])
  @@index([assignedToId])
  @@index([status])
}

// Mensajes en tickets
model TicketMessage {
  id        String   @id @default(uuid())
  message   String   @db.Text
  isInternal Boolean @default(false) // Solo visible para agentes

  // Usuario que envió el mensaje
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Ticket al que pertenece
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
}

// Knowledge Base (Base de Conocimiento)
model KnowledgeBase {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  excerpt     String?  @db.Text // Resumen corto
  slug        String   @unique // Para URLs amigables

  // Categorización
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // Estado
  status      KBStatus @default(PUBLISHED)
  isPublic    Boolean  @default(true) // Visible para clientes

  // Usuario que creó el artículo
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Metadata
  views       Int      @default(0)
  helpful     Int      @default(0) // Votos positivos
  notHelpful  Int      @default(0) // Votos negativos

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([userId])
  @@index([slug])
  @@index([status])
}

// Sistema de Citas (Appointments)
model Appointment {
  id          String              @id @default(uuid())
  date        DateTime            // Fecha exacta de la cita
  startTime   String              // Hora de inicio (Ej: "10:00")
  endTime     String              // Hora de fin (Ej: "11:30")
  status      AppointmentStatus   @default(SCHEDULED)
  notes       String?             @db.Text

  // Relaciones
  clientId    String
  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  productId   String
  product     Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([date])
  @@index([status])
}

model Notification {
  id          String              @id @default(uuid())
  type        NotificationType    // WHATSAPP, EMAIL, SYSTEM
  recipient   String              // Número de teléfono, email o ID interno
  content     String              @db.Text // Texto del mensaje
  status      NotificationStatus  @default(PENDING)
  isRead      Boolean             @default(false) // Para la campanita del cliente
  errorLog    String?             @db.Text // Log de errores si falla el envío

  // Relaciones
  clientId    String?
  client      Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([isRead])
  @@index([createdAt])
}

// Horarios Comerciales
model BusinessHour {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Domingo, 1 = Lunes, ..., 6 = Sábado
  startTime String   // Ej: "09:00" (retrocompatibilidad)
  endTime   String   // Ej: "18:00" (retrocompatibilidad)
  timeSlots String[] @default([]) // Horarios explícitos definidos por el administrador
  isOpen    Boolean  @default(true) // Si es false, ese día está cerrado
  maxAppointments Int @default(0)  // 0 = sin límite, >0 = límite máximo de citas por día

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@index([dayOfWeek])
}

model ClosedDate {
  id        String   @id @default(uuid())
  date      String   @unique // YYYY-MM-DD
  reason    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleOverride {
  id         String   @id @default(uuid())
  date       String   @unique // YYYY-MM-DD
  timeSlots  String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


// ================= Enums adicionales =================

enum CategoryType {
  PRODUCT
  TICKET
  KNOWLEDGE_BASE
}

enum ProductType {
  SAAS
  WEB_DEVELOPMENT
  SUPPORT
  MAINTENANCE
  CUSTOM_DEVELOPMENT
  CONSULTING
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  YEARLY
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum KBStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  WHATSAPP
  EMAIL
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}