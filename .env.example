# Production environment variables

# PostgreSQL credentials
POSTGRES_USER=vortex
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vortex

# Database connection string used by the backend service
DATABASE_URL=postgresql://vortex:change-me-strong-password@db:5432/vortex

# JWT secret for authentication
JWT_SECRET=replace-with-a-very-strong-secret

# Ports exposed by the compose stack
BACKEND_PORT=3000
FRONTEND_PORT=80

# Frontend API base URL used at build time
# En producción, usa el dominio público o un proxy que exponga la API.
# Ejemplo: https://app.midominio.com/api
VITE_API_BASE_URL=http://localhost:3000/api
